# This file contains common, non-secret environment variables
# Can be committed to Git.

# --- General Settings ---
TZ=Asia/Kolkata
PUID=1000
PGID=1000

# --- Node Identity ---
# Logical node name (matches Ansible inventory)
# Override this in local.env on each node: rpi-home, rpi-friend, cloud-node
NODE_NAME=rpi-home

# --- Domain Settings ---
# Used for Traefik, Authentik, etc.
DOMAIN=igh.one
ACME_EMAIL=builder023@puneeth.io

# --- Data Paths ---
# Base path for all persistent application data.
APPDATA_PATH=/srv/appdata
# Path for media files (used in pre-move backups).
MEDIA_PATH=/srv/media
# Path for backup scripts and logs.
BACKUP_PATH=/opt/backups
# Path for Docker stacks.
STACKS_PATH=/opt/stacks

# --- Database Settings ---
# Base Postgres settings
POSTGRES_USER=postgres
POSTGRES_DB=postgres
DB_DUMP_PATH=/tmp/db_dumps

# --- Rclone Backup Settings ---
# Rclone remote name for Backblaze B2 (with encryption)
# Use "b2-crypt" to use encrypted remote, or "b2" for unencrypted
RCLONE_REMOTE_NAME=b2-crypt
# Note: B2_BUCKET is defined in secrets.env

# --- Backup Automation Settings ---
# Enable automated backup cron jobs (set to true for primary nodes like rpi-home)
BACKUP_AUTOMATION_ENABLED=true
# Enable weekly mirroring to Linode Object Storage (optional)
BACKUP_MIRROR_ENABLED=false
# Enable monthly full backup with media (for pre-move period only)
BACKUP_WITH_MEDIA_ENABLED=false
